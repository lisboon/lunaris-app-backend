# ============================================================================
# Lunaris Backend — Environment Variables
# ----------------------------------------------------------------------------
# Copy this file to `.env` (never commit it) and fill in real values.
# Every variable below is actively read by the codebase; anything missing here
# but used at runtime is a bug — please keep this file in sync.
# ============================================================================

# --- Runtime --------------------------------------------------------------------
# `development` | `production` | `test`
# Controls Prisma log verbosity (production silences query logs) and can be used
# by future feature flags. Defaults to `development` when unset.
NODE_ENV=development

# HTTP port NestJS binds to. Defaults to 3001 when unset.
PORT=3001

# --- Database -------------------------------------------------------------------
# Postgres connection string consumed by Prisma (prisma.config.ts) and the
# shared PrismaClient singleton (src/infra/database/prisma.instance.ts).
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
DATABASE_URL=postgresql://lunaris:lunaris@localhost:5432/lunaris?schema=public

# --- Auth (JWT) -----------------------------------------------------------------
# Secret used by AuthModule + JwtTokenServiceImpl to sign and verify session
# tokens. MUST be a long random string in any non-local environment — boot
# fails in AuthModule if this is unset (src/infra/http/auth/auth.module.ts).
JWT_SECRET=change-me-in-production-this-must-be-a-long-random-string

# jsonwebtoken-compatible expiry (e.g. `7d`, `12h`, `30m`). Defaults to `7d`.
JWT_EXPIRES_IN=7d

# --- CORS -----------------------------------------------------------------------
# Comma-separated list of allowed origins for the browser frontend.
# Read by src/infra/http/main.ts — defaults to `http://localhost:3000` (Next
# dev server) when unset. Include every environment that will hit the API.
CORS_ORIGINS=http://localhost:3000

# --- Password hashing -----------------------------------------------------------
# bcrypt cost factor used by BcryptPasswordHashService. OWASP 2024/26 recommends
# >= 12. Must be an integer >= 10; boot fails otherwise. Tune upward on faster
# hardware without redeploying — just restart. Defaults to 12 when unset.
BCRYPT_ROUNDS=12

# --- Rate limiting --------------------------------------------------------------
# Global per-IP limit for the authenticated REST surface (per 60s window).
# Applied by the NestJS ThrottlerGuard. `/auth/login` and `/auth/register` carry
# a per-route stricter override (5/min) defined in UserController.
THROTTLE_LIMIT=30

# Per-api-key limit for the Engine M2M surface (`/missions/engine/*`), per
# window. Keyed by `x-api-key` (not IP) so studios behind NAT don't share a
# bucket. Consumed by EngineThrottlerGuard.
ENGINE_THROTTLE_LIMIT=600
ENGINE_THROTTLE_WINDOW_MS=60000

# Throttle for the `lastUsedAt` write on every Engine request. Inside this
# window, a hit that finds the key in a "recently used" state skips the UPDATE
# — killing the write-per-request in the UE5 hot path. Consumed by
# ValidateKeyUseCase via EngineFacadeFactory. Defaults to 60000 (60s).
ENGINE_LAST_USED_THROTTLE_MS=60000
