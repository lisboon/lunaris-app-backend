      "method": "DELETE",
      "url": "{{ baseUrl }}/organizations",
      "authentication": { "type": "bearer", "token": "{{ accessToken }}" },
      "headers": [],
      "description": "⚠️ Destrutivo. Soft-deleta org, members, invites pendentes **e revoga todas as api keys** na mesma transação. Responde 204.",
      "metaSortKey": -800
    },

    {
      "_id": "fld_workspaces",
