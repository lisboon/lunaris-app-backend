    {
      "_id": "fld_missions",
      "_type": "request_group",
      "parentId": "wrk_lunaris",
      "name": "4. Missions + Versions (DESIGNER)",
      "description": "Fluxo completo: create mission → save version → publish → active. `versionHash` é SHA-256 (64 hex) da `missionData` retornado pelo save-version — copie para o env.",
      "environment": {},
      "metaSortKey": -700
    },
    {
      "_id": "req_mission_create",
      "_type": "request",
      "parentId": "fld_missions",
      "name": "POST /workspaces/{ws}/missions — qst_old_country",
      "method": "POST",
      "url": "{{ baseUrl }}/workspaces/{{ workspaceId }}/missions",
      "authentication": { "type": "bearer", "token": "{{ accessToken }}" },
      "body": {
        "mimeType": "application/json",
        "text": "{\n  \"id\": \"{{ missionId }}\",\n  \"name\": \"The Old Country\",\n  \"description\": \"Opening mission of the sertão biome, introduces the two rival factions.\"\n}"
      },
      "headers": [
        { "name": "Content-Type", "value": "application/json" }
      ],
      "description": "`id` precisa casar com `^[a-z][a-z0-9_]*$`. Status inicial = DRAFT.",
      "metaSortKey": -1000
    },
    {
      "_id": "req_mission_save_version",
      "_type": "request",
      "parentId": "fld_missions",
      "name": "POST /workspaces/{ws}/missions/{id}/versions",
      "method": "POST",
      "url": "{{ baseUrl }}/workspaces/{{ workspaceId }}/missions/{{ missionId }}/versions",
      "authentication": { "type": "bearer", "token": "{{ accessToken }}" },
      "body": {
        "mimeType": "application/json",
        "text": "{\n  \"graphData\": {\n    \"nodes\": [\n      { \"id\": \"start\", \"type\": \"start\", \"position\": { \"x\": 0, \"y\": 0 }, \"data\": {} },\n      { \"id\": \"talk_npc\", \"type\": \"task\", \"position\": { \"x\": 260, \"y\": 0 }, \"data\": { \"label\": \"Talk to Dom Sebastião\" } },\n      { \"id\": \"finish\", \"type\": \"finish\", \"position\": { \"x\": 520, \"y\": 0 }, \"data\": {} }\n    ],\n    \"edges\": [\n      { \"id\": \"e1\", \"source\": \"start\", \"target\": \"talk_npc\" },\n      { \"id\": \"e2\", \"source\": \"talk_npc\", \"target\": \"finish\" }\n    ]\n  },\n  \"missionData\": {\n    \"id\": \"{{ missionId }}\",\n    \"version\": 1,\n    \"nodes\": [\n      { \"id\": \"start\", \"type\": \"start\", \"next\": [\"talk_npc\"] },\n      { \"id\": \"talk_npc\", \"type\": \"task\", \"action\": \"talk\", \"target\": \"npc_dom_sebastiao\", \"next\": [\"finish\"] },\n      { \"id\": \"finish\", \"type\": \"finish\", \"next\": [] }\n    ]\n  }\n}"
      },
      "headers": [
        { "name": "Content-Type", "value": "application/json" }
      ],
      "description": "Backend valida o DAG (tricolor DFS) e computa SHA-256 de `missionData` → `versionHash`. Copie para env.",
      "metaSortKey": -900
    },
    {
      "_id": "req_mission_publish",
      "_type": "request",
      "parentId": "fld_missions",
      "name": "PUT /workspaces/{ws}/missions/{id}/publish",
