      "environment": {},
      "environmentPropertyOrder": null,
      "metaSortKey": -1000
    },
    {
      "_id": "req_register",
      "_type": "request",
      "parentId": "fld_auth",
      "name": "POST /auth/register — João + Ubisoft",
      "method": "POST",
      "url": "{{ baseUrl }}/auth/register",
      "body": {
        "mimeType": "application/json",
        "text": "{\n  \"email\": \"joao@ubisoft.com\",\n  \"name\": \"João Pereira\",\n  \"password\": \"senha-super-forte-123\",\n  \"organizationName\": \"Ubisoft\",\n  \"organizationSlug\": \"ubisoft\"\n}"
      },
      "headers": [
        { "name": "Content-Type", "value": "application/json" }
      ],
      "description": "Cria o usuário, a organização e a Membership ADMIN no mesmo request. Responde 201 com `{ user, organization, member }`.",
      "metaSortKey": -1000
    },
    {
      "_id": "req_login",
      "_type": "request",
      "parentId": "fld_auth",
      "name": "POST /auth/login — obtém accessToken",
      "method": "POST",
      "url": "{{ baseUrl }}/auth/login",
      "body": {
        "mimeType": "application/json",
        "text": "{\n  \"email\": \"joao@ubisoft.com\",\n  \"password\": \"senha-super-forte-123\"\n}"
      },
      "headers": [
        { "name": "Content-Type", "value": "application/json" }
      ],
      "description": "Resposta: `{ accessToken, user, organization, role }`. Copie o `accessToken` e `organization.id` para o Base Environment (`accessToken` e `organizationId`).",
      "metaSortKey": -900
    },
    {
      "_id": "req_me",
      "_type": "request",
      "parentId": "fld_auth",
      "name": "GET /auth/me",
      "method": "GET",
      "url": "{{ baseUrl }}/auth/me",
      "authentication": {
        "type": "bearer",
        "token": "{{ accessToken }}"
      },
      "headers": [],
      "description": "Retorna o usuário do JWT. Útil para confirmar que o token está válido.",
      "metaSortKey": -800
    },

